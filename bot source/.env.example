# Discord Bot — AdiCheats Auth Manager

# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Your site URL (no trailing slash)
SITE_URL=https://authcore.up.railway.app/

# Your site account credentials
SITE_EMAIL=adicheatsontop@gmail.com
SITE_PASSWORD=yourcurrentpassword

# Bot prefix (for prefix commands)
PREFIX=!

# Bot accent color (hex without #)
ACCENT_COLOR=5865F2

# Firebase Authentication Config
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""

